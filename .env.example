# Supabase Configuration
# Copy this to .env and fill in your values

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:3001
# Keep VITE_API_URL for local development only.
# On Vercel production/staging, do NOT set VITE_API_URL.
# The client should call same-origin /api/download/* and let Vercel proxy it.

# For Vercel serverless proxy (/api/download/*), set this in Vercel project envs.
# Example: https://your-backend-host.com or http://your-server-ip:3001
API_SERVER_URL=

# Get these from your Supabase project:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy "Project URL" to VITE_SUPABASE_URL
# 5. Copy "anon public" key to VITE_SUPABASE_ANON_KEY
